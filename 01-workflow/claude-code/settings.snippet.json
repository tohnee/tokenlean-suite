{
  "//": "tokenlean-workflow — merge this into .claude/settings.json. Paths assume the pack is installed at .claude/. Env vars tune hook behavior (see DESIGN.md).",
  "env": {
    "//ttl": "Prefer 1h cache TTL for sparse sessions where supported.",
    "TOKENLEAN_BASH_MODE": "guard",
    "TOKENLEAN_WRITE_MODE": "guard"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/session-start.mjs" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/bash-guard.mjs" }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/write-guard.mjs" }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/precompact.mjs" }
        ]
      }
    ]
  }
}
